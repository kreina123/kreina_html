    <script>
        let data = {}; // Aggregated Tree Object
        let allRecords = []; // Original flat records from server
        let filteredData = []; // Filtered flat records
        let allGroupPaths = [];
        let lastQueriedPivots = [];
        let lastQueriedValues = [];
        let lastQueriedGlobalFilters = {};
        let isSyncing = false;
        const formattingDict = ''' + formatting_dict_json + ''';
        const allNumericCols = ''' + numeric_cols_json + ''';
        const allBooleanCols = ''' + boolean_cols_json + ''';
        const allAvailableCols = ''' + all_cols_json + ''';
        const collapsedGroups = new Set();
        const pivotFilters = {};
        const numericFilters = {};
        let globalFilters = {}; // { column: values[] or {operator, value1, value2, pick_list[]} }

        async function fetchPivotData() {
            const groupBySelect = document.getElementById('groupBy');
            const pivots = Array.from(groupBySelect.options).filter(opt => opt.selected).map(opt => opt.value);
            const valueColsSelect = document.getElementById('valueCols');
            const values = Array.from(valueColsSelect.selectedOptions).map(opt => opt.value);

            if (pivots.length === 0 || values.length === 0) {
                alert('Please select at least one pivot and one value column.');
                return;
            }

            // Capture current filter tree state
            globalFilters = JSON.parse(JSON.stringify(queryTree));

            showLoading();
            document.getElementById('queryBtn').disabled = true;
            document.getElementById('queryBtn').textContent = 'Querying...';

            try {
                const apiHost = window.location.protocol === 'file:' ? 'http://localhost:' + ''' + str(port) + ''' : '';
                const response = await fetch(apiHost + '/api/pivot', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ pivots, values, formatting_dict: formattingDict, global_filters: globalFilters })
                });
                
                if (!response.ok) throw new Error('API request failed');
                
                const result = await response.json();
                
                // Reset filters on new data query
                Object.keys(pivotFilters).forEach(k => delete pivotFilters[k]);
                Object.keys(numericFilters).forEach(k => delete numericFilters[k]);
                
                data = result.tree || {};
                allRecords = result.all_records || []; // Full records (or larger sample)
                filteredData = [...allRecords];
                grandTotalData = data._agg || {};
                
                lastQueriedPivots = [...pivots];
                lastQueriedValues = [...values];
                lastQueriedGlobalFilters = JSON.parse(JSON.stringify(globalFilters));
                checkSyncState();
                
                collapsedGroups.clear();
                renderPivotTable();
                
                // Auto-collapse if tree is large (> 1000 rows)
                const totalRows = countTreeRows(data);
                if (totalRows > 1000) {
                    collapseAll();
                    showToast('Large dataset detected: Auto-collapsed pivots');
                } else {
                    showToast('Data updated from server');
                }
            } catch (err) {
                console.error(err);
                alert('Failed to fetch data: ' + err.message);
            } finally {
                hideLoading();
                isSyncing = false;
                document.getElementById('queryBtn').disabled = false;
                document.getElementById('queryBtn').textContent = 'Query Data';
            }
        }

        function checkSyncState() {
            const groupBySelect = document.getElementById('groupBy');
            const currentPivots = Array.from(groupBySelect.options).filter(opt => opt.selected).map(opt => opt.value);
            const valueColsSelect = document.getElementById('valueCols');
            const currentValues = Array.from(valueColsSelect.selectedOptions).map(opt => opt.value);

            const container = document.getElementById('tableContainer');
            
            // Update globalFilters from current queryTree state
            globalFilters = JSON.parse(JSON.stringify(queryTree));
            
            // Logic for blurring (grey out):
            // 1. Pivots: any currently selected pivot was NOT in the last query -> Blur
            // 2. Values: any currently selected value was NOT in the last query -> Blur
            // 3. Subsets of the last query do NOT trigger blur.
            
            const pivotsSubset = currentPivots.every(p => lastQueriedPivots.includes(p));
            const valuesSubset = currentValues.every(v => lastQueriedValues.includes(v));
            
            // Check if global filters have changed
            const filtersSync = JSON.stringify(globalFilters) === JSON.stringify(lastQueriedGlobalFilters);
            
            const isOutOfSync = !pivotsSubset || !valuesSubset || !filtersSync;
            
            if (isOutOfSync) {
                container.classList.add('out-of-sync');
            } else {
                container.classList.remove('out-of-sync');
            }
            
            return isOutOfSync;
        }

        function countTreeRows(node) {
            if (!node || !node._groups) return 0;
            let count = 0;
            const keys = Object.keys(node._groups);
            count += keys.length;
            keys.forEach(key => {
                count += countTreeRows(node._groups[key]);
            });
            return count;
        }
        
        // Initial setup
        document.addEventListener('DOMContentLoaded', () => {
            // We don't render until first query
            document.getElementById('pivotTableContent').innerHTML = '<p style="padding: 20px; color: #6c757d;">Select pivots and values, then click "Query Data".</p>';
            checkSyncState(); // Check initial sync state
        });
        
        // Parse date string using format pattern
        function parseDateWithFormat(dateStr, format) {
            if (!dateStr || dateStr === '(blank)') return null;
            const str = String(dateStr).trim();
            
            // Common format patterns
            const patterns = {
                'MM/DD/YYYY': /^(\\d{1,2})\\/(\\d{1,2})\\/(\\d{4})$/,
                'M/D/YYYY': /^(\\d{1,2})\\/(\\d{1,2})\\/(\\d{4})$/,
                'MM-DD-YYYY': /^(\\d{1,2})-(\\d{1,2})-(\\d{4})$/,
                'M-D-YYYY': /^(\\d{1,2})-(\\d{1,2})-(\\d{4})$/,
                'YYYY-MM-DD': /^(\\d{4})-(\\d{1,2})-(\\d{1,2})$/,
                'YYYY/MM/DD': /^(\\d{4})\\/(\\d{1,2})\\/(\\d{1,2})$/,
                'DD/MM/YYYY': /^(\\d{1,2})\\/(\\d{1,2})\\/(\\d{4})$/,
                'DD-MM-YYYY': /^(\\d{1,2})-(\\d{1,2})-(\\d{4})$/
            };
            
            const pattern = patterns[format] || patterns['MM/DD/YYYY'];
            const match = str.match(pattern);
            if (!match) return null;
            
            let year, month, day;
            if (format && format.startsWith('YYYY')) {
                [, year, month, day] = match;
            } else if (format && format.startsWith('DD')) {
                [, day, month, year] = match;
            } else {
                [, month, day, year] = match;
            }
            return new Date(parseInt(year), parseInt(month) - 1, parseInt(day)).getTime();
        }
        
        // Get sort comparator for a column
        function getSortComparator(col) {
            const config = formattingDict[col] || {};
            const sortType = config.type || 'text';
            const order = config.order || 'asc';
            const dateFormat = config.format || 'MM/DD/YYYY';
            const multiplier = order === 'desc' ? -1 : 1;
            
            if (sortType === 'date') {
                return (a, b) => {
                    const dateA = parseDateWithFormat(a, dateFormat);
                    const dateB = parseDateWithFormat(b, dateFormat);
                    if (dateA === null && dateB === null) return 0;
                    if (dateA === null) return 1;
                    if (dateB === null) return -1;
                    return (dateA - dateB) * multiplier;
                };
            } else if (sortType === 'number') {
                return (a, b) => {
                    const numA = parseFloat(a);
                    const numB = parseFloat(b);
                    if (isNaN(numA) && isNaN(numB)) return 0;
                    if (isNaN(numA)) return 1;
                    if (isNaN(numB)) return -1;
                    return (numA - numB) * multiplier;
                };
            } else {
                // Text sort
                return (a, b) => {
                    const strA = String(a || '');
                    const strB = String(b || '');
                    return strA.localeCompare(strB) * multiplier;
                };
            }
        }
        
        // Get aggregation result based on node or calculated rows
        function getAggregationResult(node, col) {
            // Priority 1: Server-precalculated aggregation
            if (node && node._agg && node._agg[col] !== undefined) {
                return node._agg[col];
            }
            
            // Priority 2: Fallback to client-side calc if records are available
            const rows = Array.isArray(node) ? node : (node && node._groups ? flattenTree(node) : []);
            if (rows.length === 0) return null;

            const config = formattingDict[col] || {};
            const aggOp = config.agg || 'sum';
            const nullOnNulls = config.null_on_nulls || false;
            const valCol = config.val_col || col;
            
            const values = rows.map(r => {
                const val = r[valCol];
                return (val === null || val === undefined) ? null : parseFloat(val);
            });
            
            const hasNulls = values.some(v => v === null);
            if (nullOnNulls && hasNulls) return null;
            
            const nonNullValues = values.filter(v => v !== null && !isNaN(v));
            if (nonNullValues.length === 0) return null;
            
            switch (aggOp) {
                case 'avg': return nonNullValues.reduce((a, b) => a + b, 0) / nonNullValues.length;
                case 'min': return Math.min(...nonNullValues);
                case 'max': return Math.max(...nonNullValues);
                case 'count': return nonNullValues.length;
                case 'median':
                    nonNullValues.sort((a, b) => a - b);
                    const mid = Math.floor(nonNullValues.length / 2);
                    return nonNullValues.length % 2 !== 0 ? nonNullValues[mid] : (nonNullValues[mid - 1] + nonNullValues[mid]) / 2;
                case 'mode':
                    const frequency = {};
                    let maxFreq = 0;
                    let mode = null;
                    nonNullValues.forEach(v => {
                        frequency[v] = (frequency[v] || 0) + 1;
                        if (frequency[v] > maxFreq) {
                            maxFreq = frequency[v];
                            mode = v;
                        }
                    });
                    return mode;
                case 'std':
                    const mean = nonNullValues.reduce((a, b) => a + b, 0) / nonNullValues.length;
                    const variance = nonNullValues.reduce((a, b) => a + Math.pow(b - mean, 2), 0) / nonNullValues.length;
                    return Math.sqrt(variance);
                case 'weighted_avg':
                    const weightsCol = config.weights_col;
                    if (!weightsCol) return null;
                    const weights = rows.map(r => {
                        const val = r[weightsCol];
                        return (val === null || val === undefined) ? null : parseFloat(val);
                    });
                    if (nullOnNulls && weights.some(v => v === null)) return null;
                    
                    let weightedSum = 0;
                    let weightTotal = 0;
                    for (let i = 0; i < values.length; i++) {
                        if (values[i] !== null && weights[i] !== null) {
                            weightedSum += values[i] * weights[i];
                            weightTotal += weights[i];
                        }
                    }
                    return weightTotal === 0 ? null : weightedSum / weightTotal;
                default: return nonNullValues.reduce((a, b) => a + b, 0);
            }
        }
        
        // Large dataset handling
        const LARGE_DATA_THRESHOLD = 5000;
        const isLargeDataset = false; // We use API for large data, virtual scroll still works on rendered rows.
        
        function showLoading() {
            document.getElementById('loadingOverlay').classList.remove('hidden');
        }
        
        function hideLoading() {
            document.getElementById('loadingOverlay').classList.add('hidden');
        }
        
        // Mark scroll container for large datasets
        if (isLargeDataset) {
            document.addEventListener('DOMContentLoaded', () => {
                const container = document.getElementById('scrollContainer');
                if (container) container.classList.add('large-data');
            });
        }
        
        function handleSelectMouseDown(event, selectId) {
            const option = event.target;
            if (option.tagName === 'OPTION') {
                event.preventDefault(); // Prevent default to enable toggle behavior
                option.selected = !option.selected; // Toggle selection

                // Trigger change event
                const select = document.getElementById(selectId);
                select.dispatchEvent(new Event('change'));

                handleSelectChange(selectId);
            }
        }

        function handleSelectChange(selectId) {
            // Check sync state FIRST to determine if we should re-render
            const isOutOfSync = checkSyncState();
            
            // If out-of-sync (not a subset of last query), DON'T re-render the table
            // Just gray it out and wait for user to click "Query Data"
            if (isOutOfSync) {
                // Table is already grayed out by checkSyncState(), no need to re-render
                return;
            }
            
            // Only re-render if selection is a subset of last queried columns
            collapsedGroups.clear();
            if (selectId === 'groupBy') {
                Object.keys(pivotFilters).forEach(k => delete pivotFilters[k]);
            }
            renderPivotTable();
        }
        
        function expandAll() {
            collapsedGroups.clear();
            document.querySelectorAll('.group-row').forEach(row => {
                row.classList.remove('collapsed');
                row.classList.remove('hidden');
            });
        }
        
        function collapseAll() {
            // Collapse only top-level groups (level 0)
            document.querySelectorAll('.group-row[data-level="0"]').forEach(row => {
                const path = row.getAttribute('data-path');
                collapsedGroups.add(path);
                row.classList.add('collapsed');
            });
            // Hide all non-level-0 rows
            document.querySelectorAll('.group-row').forEach(row => {
                const level = parseInt(row.getAttribute('data-level'));
                if (level > 0) row.classList.add('hidden');
            });
        }
        
        function initFilters(cols) {
            cols.forEach(col => {
                if (!pivotFilters[col]) {
                    const uniqueValues = [...new Set(allRecords.map(row => {
                        let val = row[col];
                        if (typeof val === 'boolean') val = val ? 'True' : 'False';
                        return val !== null && val !== undefined ? String(val) : '(blank)';
                    }))];
                    pivotFilters[col] = new Set(uniqueValues);
                }
            });
        }

        function getFilteredData(excludeCol = null) {
            return allRecords.filter(row => {
                // Pivot Filters
                for (const col in pivotFilters) {
                    if (col === excludeCol) continue;
                    let val = row[col];
                    if (typeof val === 'boolean') val = val ? 'True' : 'False';
                    const valStr = val !== null && val !== undefined ? String(val) : '(blank)';
                    if (!pivotFilters[col].has(valStr)) return false;
                }
                
                // Numeric Column Filters (from grid column menu) - NOW POST-AGGREGATION
                // We no longer filter raw records here for numeric value columns.
                // Boolean column filters on raw data (if they are treated as Dimensions) could stay, 
                // but if they are treated as Values (Aggregates), they should also be post-agg.
                // For now, we assume numeric/value column filters are applied in renderTree.
                
                // Exception: If a Boolean column is used as a Dimension (Pivot), it is handled by pivotFilters above.
                // If it's used as a Value, it shouldn't be here in getFilteredData for raw record filtering.
                
                 /* 
                  * PREVIOUS LOGIC REMOVED
                  * Post-aggregation logic moved to renderTree/renderPivotTable
                  */
                
                // Global Filters (Recursive Tree)
                if (globalFilters && globalFilters.type === 'group') {
                     if (!checkFilterNode(row, globalFilters)) return false;
                }
                
                return true;
            });
        }

        function checkFilterNode(row, node) {
            if (node.type === 'rule') {
                const col = node.column;
                if (!col) return true;
                
                // Ignore empty filters - if value is empty string, rule is skipped
                if (node.value === '' || node.value === undefined || node.value === null) return true;
                
                let rowVal = row[col];
                if (rowVal === null || rowVal === undefined) rowVal = '';
                
                const op = node.operator;
                const v1 = node.value;
                const v2 = node.value2; // for between
                
                // Numeric handling
                const isNumericCol = allNumericCols.includes(col);
                if (isNumericCol) {
                    if (allBooleanCols.includes(col)) {
                        const bVal = String(rowVal).toLowerCase() === 'true';
                        const bV1 = String(v1).toLowerCase() === 'true';
                        if (op === 'equals') return bVal === bV1;
                        if (op === 'notEquals') return bVal !== bV1;
                        return true; // For boolean, only equals/notEquals are meaningful. Other ops are ignored.
                    }
                    const numVal = parseFloat(rowVal);
                    const numV1 = parseFloat(v1);
                    const numV2 = parseFloat(v2);
                    
                    if (isNaN(numVal)) return false; 
                    
                    if (op === 'equals') return numVal === numV1;
                    if (op === 'notEquals') return numVal !== numV1;
                    if (op === 'greaterThan') return numVal > numV1;
                    if (op === 'greaterThanOrEqual') return numVal >= numV1;
                    if (op === 'lessThan') return numVal < numV1;
                    if (op === 'lessThanOrEqual') return numVal <= numV1;
                    if (op === 'between') return numVal >= numV1 && numVal <= numV2;
                } else {
                    // String/Date handling
                    const strVal = String(rowVal).toLowerCase();
                    const strV1 = String(v1).toLowerCase();
                    const strV2 = String(v2).toLowerCase();
                    
                    if (op === 'equals') return strVal === strV1;
                    if (op === 'notEquals') return strVal !== strV1;
                    // Date/string comparison operators
                    if (op === 'greaterThan') return strVal > strV1;
                    if (op === 'greaterThanOrEqual') return strVal >= strV1;
                    if (op === 'lessThan') return strVal < strV1;
                    if (op === 'lessThanOrEqual') return strVal <= strV1;
                    if (op === 'between') return strVal >= strV1 && strVal <= strV2;
                }
                return true;
            }
            
            if (node.type === 'group') {
                 const children = node.children || [];
                 if (children.length === 0) return true;
                 
                 const logic = node.logic; // AND / OR
                 
                 if (logic === 'OR') {
                     // ANY match
                     return children.some(child => checkFilterNode(row, child));
                 } else {
                     // ALL match
                     return children.every(child => checkFilterNode(row, child));
                 }
            }
            
            return true;
        }
        
        window.addEventListener('keydown', function(event) {
            if (event.key === 'Enter') {
                const openDropdown = document.querySelector('.filter-dropdown.show');
                if (openDropdown) {
                    event.preventDefault();
                    event.stopPropagation();
                    
                    // If focusing on a decimal input, just close the modal.
                    // The surgical update was already triggered by 'onchange'.
                    const active = document.activeElement;
                    const isDecimal = active && active.tagName === 'INPUT' && active.type === 'number' && active.parentElement.querySelector('label')?.textContent.includes('Decimals');
                    
                    if (isDecimal) {
                        closeAllDropdowns();
                    } else {
                        applyColumnFilter();
                    }
                }
            }
        }, true);
        
        function applyFilters() {
            filteredData = getFilteredData();
            renderPivotTable();
        }
        
        let activeSort = { col: null, dir: 'asc' };

        function toggleSort(col, event) {
            // Don't sort if clicking filter icon
            if (event.target.closest('.filter-icon')) return;
            
           if (activeSort.col === col) {
               activeSort.dir = activeSort.dir === 'asc' ? 'desc' : 'asc';
           } else {
               activeSort.col = col;
               activeSort.dir = 'asc';
           }
           renderPivotTable();
        }

        function showFilterDropdown(col, type, event) {
            event.stopPropagation();
            closeAllDropdowns();
            const dropdown = document.getElementById('dropdown-' + col.replace(/[^a-zA-Z0-9]/g, '_'));
            if (dropdown) {
                const th = event.target.closest('th');
                const rect = th.getBoundingClientRect();
                
                // Show it first to measure
                dropdown.classList.add('show');
                const dropRect = dropdown.getBoundingClientRect();
                
                let top = rect.bottom + 1;
                let left = rect.left;
                
                // Viewport collision detection
                const margin = 10;
                
                // Flip up if it goes off bottom
                if (top + dropRect.height > window.innerHeight) {
                    const flipTop = rect.top - dropRect.height - 1;
                    if (flipTop > 0) {
                        top = flipTop;
                    } else {
                        // If it doesn't fit either way, cap it at the bottom of viewport
                        top = window.innerHeight - dropRect.height - margin;
                    }
                }
                
                // Horizontal bounds
                if (left + dropRect.width > window.innerWidth) {
                    left = window.innerWidth - dropRect.width - margin;
                }
                if (left < margin) left = margin;
                
                dropdown.style.top = top + 'px';
                dropdown.style.left = left + 'px';
            }
        }
        
        // Close dropdowns on scroll to maintain alignment
        window.addEventListener('scroll', () => closeAllDropdowns(), { capture: true });
        
        function closeAllDropdowns() {
            document.querySelectorAll('.filter-dropdown').forEach(d => d.classList.remove('show'));
        }
        
        function toggleFilterValue(col, value) {
            if (pivotFilters[col].has(value)) pivotFilters[col].delete(value);
            else pivotFilters[col].add(value);
        }
        
        function selectAll(col) {
            const contextData = getFilteredData(col);
            const availableValues = [...new Set(contextData.map(row => {
                let val = row[col];
                if (typeof val === 'boolean') val = val ? 'True' : 'False';
                return val !== null && val !== undefined ? String(val) : '(blank)';
            }))];
            availableValues.forEach(val => pivotFilters[col].add(val));
            document.querySelectorAll('#options-' + col.replace(/[^a-zA-Z0-9]/g, '_') + ' input').forEach(cb => {
                if (cb.offsetParent !== null) cb.checked = true; // Only visible ones
            });
        }
        
        function selectNone(col) {
            pivotFilters[col] = new Set();
            document.querySelectorAll('#options-' + col.replace(/[^a-zA-Z0-9]/g, '_') + ' input').forEach(cb => cb.checked = false);
        }
        
        function searchFilter(input, col) {
            const term = input.value.toLowerCase();
            document.querySelectorAll('#options-' + col.replace(/[^a-zA-Z0-9]/g, '_') + ' .filter-option').forEach(opt => {
                const val = opt.getAttribute('data-value').toLowerCase();
                opt.style.display = val.includes(term) ? 'flex' : 'none';
            });
        }
        
        function updateNumericFilter(col, field, value) {
            if (!numericFilters[col]) numericFilters[col] = { operator: 'none', value1: '', value2: '' };
            if (!formattingDict[col]) formattingDict[col] = {};
            
            if (field === 'agg' || field === 'weights_col' || field === 'null_on_nulls' || field === 'val_col' || field === 'decimals') {
                if (field === 'decimals') {
                    const currentFmt = formattingDict[col].fmt || '';
                    const prefix = currentFmt.startsWith('percent') ? 'percent' : 'decimal';
                    formattingDict[col].fmt = prefix + value;
                    // Update ONLY the value cells for this column
                    document.querySelectorAll('td.value-cell[data-col="' + col + '"]').forEach(cell => {
                        const raw = cell.getAttribute('data-raw');
                        if (raw && raw !== '') {
                            cell.textContent = formatValue(parseFloat(raw), col);
                        }
                    });
                } else {
                    formattingDict[col][field] = value;
                    if (field === 'agg') {
                        const weightsSelect = document.getElementById('weights-select-' + col.replace(/[^a-zA-Z0-9]/g, '_'));
                        if (weightsSelect) weightsSelect.style.display = value === 'weighted_avg' ? 'block' : 'none';
                    }
                    checkSyncState(); // Changing aggregation requires re-query
                }
            } else {
                numericFilters[col][field] = value;
                if (field === 'operator') renderNumericInputs(col);
            }
        }
        
        function renderNumericInputs(col) {
            const container = document.getElementById('numeric-inputs-' + col.replace(/[^a-zA-Z0-9]/g, '_'));
            if (!container) return;
