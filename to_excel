    pivots = config.get('pivots', [])
    values = config.get('values', [])
    formatting_dict = config.get('formatting_dict', {})
    global_filters = config.get('global_filters', {})
    
    # Debug logging
    import sys
    print(f"\n[DEBUG] pivot_api called:", file=sys.stderr)
    print(f"  Pivots: {pivots}", file=sys.stderr)
    print(f"  Values: {values}", file=sys.stderr)
    print(f"  Global Filters: {json.dumps(global_filters)}", file=sys.stderr)
    print(f"  DataFrame shape: {GLOBAL_DF.shape if GLOBAL_DF is not None else 'None'}", file=sys.stderr)
    
    if GLOBAL_DF is None or not pivots:
        return jsonify({'tree': {}, 'flat_data': []})

    # Hierarchical aggregation logic
    def calculate_aggs(group_df, values_list, sorting_config):
        aggs = {}
        for col in values_list:
            conf = sorting_config.get(col, {})
            agg_op = conf.get('agg', 'sum')
            null_on_nulls = conf.get('null_on_nulls', False)
            
            if group_df.empty:
                aggs[col] = None
                continue
                
            series_col = conf.get('val_col', col)
            if series_col not in group_df.columns:
                aggs[col] = None
                continue
                
            series = pd.to_numeric(group_df[series_col], errors='coerce')
            
            if agg_op == 'weighted_avg':
                weights_col = conf.get('weights_col')
                if not weights_col or weights_col not in group_df.columns:
                    aggs[col] = None
                    continue
                weights_series = pd.to_numeric(group_df[weights_col], errors='coerce')
                
                if null_on_nulls and (series.isnull().any() or weights_series.isnull().any()):
                    aggs[col] = None
                    continue
                
                mask = series.notnull() & weights_series.notnull()
                v = series[mask]
                w = weights_series[mask]
                
                if w.empty or w.sum() == 0:
                    aggs[col] = None
                else:
                    aggs[col] = float((v * w).sum() / w.sum())
                continue

            if null_on_nulls and series.isnull().any():
                aggs[col] = None
                continue
                
            non_null = series.dropna()
            if non_null.empty:
                aggs[col] = None
                continue
            
            if agg_op == 'avg': aggs[col] = float(non_null.mean())
            elif agg_op == 'min': aggs[col] = float(non_null.min())
            elif agg_op == 'max': aggs[col] = float(non_null.max())
            elif agg_op == 'count': aggs[col] = int(len(non_null))
            elif agg_op == 'median': aggs[col] = float(non_null.median())
            elif agg_op == 'mode':
                 modes = non_null.mode()
                 aggs[col] = float(modes.iloc[0]) if not modes.empty else None
            elif agg_op == 'std': aggs[col] = float(non_null.std())
            else: aggs[col] = float(non_null.sum())
            
            # Sanitize individual aggregation result
            aggs[col] = sanitize_for_json(aggs[col])
        return aggs

    def build_tree_python(df, current_pivots, value_cols, sorting_config, current_level=0):
        # Calculate aggregations for THIS node (the group itself)
        node_aggs = calculate_aggs(df, value_cols, sorting_config)
        
        if current_level >= len(current_pivots):
            return {"_agg": node_aggs} # Leaf node just returns its aggregations
        
        col = current_pivots[current_level]
        groups = df.groupby(col, dropna=False)
        
        result = {"_groups": {}, "_sortedKeys": [], "_agg": node_aggs}
        
        for name, group_df in groups:
            key = str(name) if pd.notnull(name) else "(blank)"
            
            # Sub-tree
            children = build_tree_python(group_df, current_pivots, value_cols, sorting_config, current_level + 1)
            result["_groups"][key] = children
            result["_sortedKeys"].append(key)
            
        return result

    df = GLOBAL_DF.copy()
    
    def normalize_date_string(date_str):
        """Convert various date formats to YYYY-MM-DD for comparison"""
        if not date_str or date_str == '' or date_str == '(blank)':
            return None
        
        import re
        date_str = str(date_str).strip()
        
        # Try common patterns: M/D/YYYY, MM/DD/YYYY, YYYY-MM-DD, MM-DD-YYYY
        patterns = [
            (r'^(\d{1,2})/(\d{1,2})/(\d{4})$', lambda m: f"{m.group(3)}-{m.group(1):0>2}-{m.group(2):0>2}"),  # M/D/YYYY or MM/DD/YYYY
            (r'^(\d{4})-(\d{1,2})-(\d{1,2})$', lambda m: f"{m.group(1)}-{m.group(2):0>2}-{m.group(3):0>2}"),    # YYYY-MM-DD
            (r'^(\d{1,2})-(\d{1,2})-(\d{4})$', lambda m: f"{m.group(3)}-{m.group(1):0>2}-{m.group(2):0>2}"),    # M-D-YYYY
            (r'^(\d{1,2})\.(\d{1,2})\.(\d{4})$', lambda m: f"{m.group(3)}-{m.group(1):0>2}-{m.group(2):0>2}"),   # M.D.YYYY
        ]
        
        for pattern, converter in patterns:
            match = re.match(pattern, date_str)
            if match:
                try:
                    return converter(match)
                except:
                    pass
        
        return None
    
    def apply_filter_condition(df, col, op, v1, v2):
        try:
            # Detect if column likely contains dates (by name or by checking values)
            col_lower = col.lower()
            is_date_col = 'date' in col_lower or 'time' in col_lower
            
            # Handle numeric conversion safely
            if (df[col].dtype.kind in 'bcifu'): # types: bool, complex, signed int, float, unsigned int
                if df[col].dtype == 'bool':
                    # Support boolean comparison
                    b_val = str(v1).lower() == 'true'
                    if op == 'equals': return df[col] == b_val
                    elif op == 'notEquals': return df[col] != b_val
                    return pd.Series(True, index=df.index)

                val1 = float(v1) if v1 is not None and v1 != '' else 0
                val2 = float(v2) if v2 is not None and v2 != '' else 0
                
                if op == 'equals': return df[col] == val1
                elif op == 'notEquals': return df[col] != val1
                elif op == 'greaterThan': return df[col] > val1
                elif op == 'greaterThanOrEqual': return df[col] >= val1
                elif op == 'lessThan': return df[col] < val1
                elif op == 'lessThanOrEqual': return df[col] <= val1
                elif op == 'between': return (df[col] >= val1) & (df[col] <= val2)
            else:
                # String/Date handling
                if is_date_col:
                    # Try to normalize dates for comparison
                    normalized_v1 = normalize_date_string(v1)
                    normalized_v2 = normalize_date_string(v2)
                    
                    if normalized_v1:
                        # Convert column to normalized dates too
                        normalized_col = df[col].apply(normalize_date_string)
                        
                        if op == 'equals': return normalized_col == normalized_v1
                        elif op == 'notEquals': return normalized_col != normalized_v1
                        elif op == 'greaterThan': return normalized_col > normalized_v1
                        elif op == 'greaterThanOrEqual': return normalized_col >= normalized_v1
                        elif op == 'lessThan': return normalized_col < normalized_v1
                        elif op == 'lessThanOrEqual': return normalized_col <= normalized_v1
                        elif op == 'between' and normalized_v2:
                            return (normalized_col >= normalized_v1) & (normalized_col <= normalized_v2)
                
                # Fall back to string comparison
                val1_str = str(v1).lower() if v1 else ''
                val2_str = str(v2).lower() if v2 else ''
                series_str = df[col].astype(str).str.lower().fillna('')
                
                if op == 'equals': return series_str == val1_str
                elif op == 'notEquals': return series_str != val1_str
                elif op == 'greaterThan': return series_str > val1_str
                elif op == 'greaterThanOrEqual': return series_str >= val1_str
                elif op == 'lessThan': return series_str < val1_str
                elif op == 'lessThanOrEqual': return series_str <= val2_str
                elif op == 'between': return (series_str >= val1_str) & (series_str <= val2_str)
                 
        except Exception as e:
             print(f"[DEBUG] Filter error on col={col}, op={op}, v1={v1}, v2={v2}: {e}")
             return pd.Series(False, index=df.index)
        return pd.Series(True, index=df.index)

    def apply_filter_node(df, node):
        node_type = node.get('type')
        
        # Base Case: Rule
        if node_type == 'rule':
            col = node.get('column')
            if not col or col not in df.columns: return pd.Series(True, index=df.index)
            
            # Skip empty filters - if value is empty, treat as no filter on this rule
            v1 = node.get('value')
            if v1 == '' or v1 is None:
                return pd.Series(True, index=df.index)
            
            # For 'between' operator, require both values
            op = node.get('operator')
            if op == 'between':
                v2 = node.get('value2')
                if v2 == '' or v2 is None:
                    # Skip between filter if max value is missing
                    print(f"[DEBUG] Skipping 'between' filter on {col}: min={v1}, max={v2}", file=sys.stderr)
                    return pd.Series(True, index=df.index)
            
            return apply_filter_condition(df, col, op, v1, node.get('value2'))
        
        # Recursive Case: Group
        if node_type == 'group':
            children = node.get('children', [])
            if not children: return pd.Series(True, index=df.index)
            
            logic = node.get('logic', 'AND')
            group_mask = None
            
            for child in children:
                child_mask = apply_filter_node(df, child)
                if group_mask is None:
                    group_mask = child_mask
                elif logic == 'OR':
                    group_mask = group_mask | child_mask
                else: # AND
                    group_mask = group_mask & child_mask
            
            return group_mask if group_mask is not None else pd.Series(True, index=df.index)
            
        return pd.Series(True, index=df.index)

    # Detect if global_filters is a Tree (Root Group) or Legacy Map
    # Tree typically has 'type': 'group' and 'children' at top level
    is_tree = isinstance(global_filters, dict) and global_filters.get('type') == 'group'
    
    if is_tree:
        # Apply recursive tree Logic
        mask = apply_filter_node(df, global_filters)
        if mask is not None: 
            rows_before = len(df)
            df = df[mask]
            rows_after = len(df)
            print(f"[DEBUG] Filter applied: {rows_before} -> {rows_after} rows", file=sys.stderr)
        
    else:
        # LEGACY / FLAT MAP SUPPORT (Backwards Compatibility)
        for col, v in global_filters.items():
            if col not in df.columns: continue
            if isinstance(v, list): df = df[df[col].astype(str).fillna('(blank)').isin(v)]
            elif isinstance(v, dict):
                # Handle complex filter (per-column AND/OR)
                if v.get('type') == 'complex':
                    logic = v.get('logic', 'AND')
                    conditions = v.get('conditions', [])
                    if not conditions: continue
                    
                    # Combine conditions
                    mask = None
                    for cond in conditions:
                        op, v1, v2 = cond.get('operator'), cond.get('value1'), cond.get('value2')
                        cond_mask = apply_filter_condition(df, col, op, v1, v2)
                        
                        if mask is None: mask = cond_mask
                        elif logic == 'OR': mask = mask | cond_mask
                        else: mask = mask & cond_mask
                    
                    if mask is not None: df = df[mask]
                
                # Legacy/Simple fallthrough
                else:
                    op, v1, v2 = v.get('operator'), v.get('value1'), v.get('value2')
                    mask = apply_filter_condition(df, col, op, v1, v2)
                    df = df[mask]
    filtered_df = df
    tree = build_tree_python(filtered_df, pivots, values, formatting_dict)
    
    return jsonify(sanitize_for_json({
        'tree': tree,
        'flat_data': [], # No longer needed for aggregation, saves memory
        'all_records': filtered_df.to_dict('records') # Full dataset for accurate client-side filtering
    }))

