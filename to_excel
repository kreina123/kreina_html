    all_numeric_cols = df.select_dtypes(include=['number', 'bool']).columns.tolist()
    all_non_numeric_cols = df.select_dtypes(exclude=['number']).columns.tolist()
    all_boolean_cols = df.select_dtypes(include=['bool']).columns.tolist()
    all_cols = list(df.columns)
    
    # Add derived columns from formatting_dict
    if formatting_dict:
        for col, conf in formatting_dict.items():
            if isinstance(conf, dict):
                 # Add to numeric/value cols
                 if col not in all_numeric_cols:
                     all_numeric_cols.append(col)
                 
                 # Add to all_cols if it exists in DF (so it appears in column lists)
                 if col in df.columns and col not in all_cols:
                      all_cols.append(col)
                 
                 # Add to pivot_cols candidates (Pivots dropdown)
                 # We allow derived columns to be pivots if requested (assuming user wants them)
                 if col not in all_non_numeric_cols:
                      all_non_numeric_cols.append(col)

    if pivot_cols is None:
        pivot_cols = all_non_numeric_cols
    
    if value_cols is None:
        value_cols = [c for c in all_numeric_cols if c in df.columns]
    elif isinstance(value_cols, str):
        value_cols = [value_cols]
    
    # Ensure any requested derived columns are in value_cols
    if formatting_dict:
        for col, conf in formatting_dict.items():
            if isinstance(conf, dict) and conf.get('agg') == 'weighted_avg':
                if col not in value_cols:
                    value_cols.append(col)
                if default_values is not None and col not in default_values and conf.get('default'):
                     default_values.append(col)
    
    if default_pivots is None and pivot_cols:
        default_pivots = [pivot_cols[0]]
    elif default_pivots is None:
        default_pivots = []
    elif isinstance(default_pivots, str):
        default_pivots = [default_pivots]
        
    if default_values is None:
        default_values = value_cols
    elif isinstance(default_values, str):
        default_values = [default_values]

    if formatting_dict is None:
        formatting_dict = {}

    formatting_dict_json = json.dumps(formatting_dict)
    numeric_cols_json = json.dumps(all_numeric_cols)
    boolean_cols_json = json.dumps(all_boolean_cols)
    all_cols = list(df.columns)
    all_cols_json = json.dumps(all_cols)
    
    pivot_options = '\n'.join([
        f'<option value="{col}" {"selected" if col in default_pivots else ""}>{col}</option>' 
        for col in pivot_cols
    ])
    
