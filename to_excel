        /**
         * Enhanced Searchable Select logic:
         * Show all options on focus/click even if a value is present.
         * Filter only when typing.
         */
        function setupSearchableInput(input, onValueChange) {
            let lastValue = input.value;
            let isClearingForFocus = false;

            input.addEventListener('mousedown', () => {
                if (input.value) {
                    lastValue = input.value;
                    isClearingForFocus = true;
                    input.value = ''; // Temporarily clear to show all datalist options
                }
            });

            input.addEventListener('focus', () => {
                if (input.value && !isClearingForFocus) {
                    lastValue = input.value;
                    input.value = '';
                }
                isClearingForFocus = false;
            });

            input.addEventListener('input', (e) => {
                const newVal = e.target.value;
                // If the value matches one of the datalist options exactly, or if user is typing...
                lastValue = newVal;
                onValueChange(newVal);
            });

            input.addEventListener('blur', () => {
                if (input.value === '' && lastValue !== '') {
                    input.value = lastValue;
                }
                isClearingForFocus = false;
            });
            
            // For opSelect and simple inputs
            input.addEventListener('keydown', (e) => {
                if (e.key === 'Enter') input.blur();
            });
        }

        function getColorForColumn(col) {
            let hash = 0;
            for (let i = 0; i < col.length; i++) {
                hash = col.charCodeAt(i) + ((hash << 5) - hash);
            }
            const h = Math.abs(hash % 360);
            return `rgb(${hsvToRgb(h / 360, 0.7, 0.6).join(',')})`;
        }

        function hsvToRgb(h, s, v) {
            let r, g, b;
            let i = Math.floor(h * 6);
            let f = h * 6 - i;
            let p = v * (1 - s);
            let q = v * (1 - f * s);
            let t = v * (1 - (1 - f) * s);
            switch (i % 6) {
                case 0: r = v, g = t, b = p; break;
                case 1: r = q, g = v, b = p; break;
                case 2: r = p, g = v, b = t; break;
                case 3: r = p, g = q, b = v; break;
                case 4: r = t, g = p, b = v; break;
                case 5: r = v, g = p, b = q; break;
            }
            return [Math.round(r * 255), Math.round(g * 255), Math.round(b * 255)];
        }
