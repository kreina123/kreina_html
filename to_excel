@app.route('/api/unique_values', methods=['POST'])
def unique_values():
    config = request.json
    col = config.get('column')
    search = config.get('search_term', '').lower()
    if GLOBAL_DF is None or col not in GLOBAL_DF.columns: return jsonify([])
    
    vals = GLOBAL_DF[col].astype(str).fillna('(blank)').unique().tolist()
    if search: vals = [v for v in vals if search in v.lower()]
    
    try:
        vals = sorted(vals, key=lambda x: float(x) if x != '(blank)' else -float('inf'))
    except:
        vals = sorted(vals)
    return jsonify(vals[:1000])

