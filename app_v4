def get_column_filter_options(col_name, selected_val=None):
    """Get filter options for a column. Returns options list for dropdown.
    For columns with >100 unique values, returns fewer options but enables search."""
    if col_name not in df.columns:
        return []
    
    unique_vals = df[col_name].dropna().unique()
    
    # For boolean columns, always show True/False
    if pd.api.types.is_bool_dtype(df[col_name].dtype):
        return [{"label": "True", "value": "True"}, {"label": "False", "value": "False"}]
    
    # For numeric columns, don't prepopulate (user will type)
    if pd.api.types.is_numeric_dtype(df[col_name].dtype):
        return []
    
    # For categorical/string columns
    if len(unique_vals) <= 100:
        return [{"label": str(v), "value": str(v)} for v in sorted(unique_vals, key=str)]
    else:
        # Return first 50 sorted values, user can search for more
        sorted_vals = sorted(unique_vals, key=str)[:50]
        return [{"label": str(v), "value": str(v)} for v in sorted_vals]

def create_filter_group_component(node, path_id, level=0):
    """
    Recursively create a filter group component.
    path_id: A hyphen-separated string of indices to locate this node (e.g., 'root', 'root-0', 'root-0-1')
             'root' is top level. 'root-0' is first child of root.
    """
    node_type = node.get("type", "group")
    
    # Indentation style
    style = {
        "marginLeft": "20px" if level > 0 else "0px",
        "borderLeft": "2px solid #e0e0e0" if level > 0 else "none",
        "paddingLeft": "10px" if level > 0 else "0px",
        "marginTop": "10px",
        "marginBottom": "10px"
    }

    if node_type == "group":
        children_nodes = node.get("children", [])
        logic = node.get("logic", "AND")
        
        children_components = []
        for i, child in enumerate(children_nodes):
            child_path = f"{path_id}-{i}"
            children_components.append(create_filter_group_component(child, child_path, level + 1))
            
        return html.Div(style=style, className="filter-group", children=[
            # Group Header
            html.Div(className="group-header", style={"display": "flex", "alignItems": "center", "marginBottom": "5px"}, children=[
                # Delete Group Button
                html.Button("× Group", id={"type": "filter-group-remove", "path": path_id}, 
                           className="btn btn-xs btn-outline-danger",
                           style={"marginRight": "10px", "display": "none" if level == 0 else "block"}),
                
                # Logic Toggle (AND/OR)
                dcc.RadioItems(
                    id={"type": "filter-group-logic", "path": path_id},
                    options=[
                        {"label": "AND", "value": "AND"},
                        {"label": "OR", "value": "OR"}
                    ],
                    value=logic,
                    inline=True,
                    className="logic-radio-small",
                    inputStyle={"marginRight": "5px"},
                    labelStyle={"marginRight": "10px", "fontWeight": "600", "fontSize": "0.9em"}
                ),
            ]),
            
            # Children container
            html.Div(children=children_components),
            
            # Footer buttons to add rule/group
            html.Div(className="group-footer", style={"marginTop": "5px"}, children=[
                html.Button("+ Rule", id={"type": "filter-add-rule", "path": path_id}, 
                           className="btn btn-xs btn-secondary", style={"marginRight": "5px"}),
                html.Button("+ Group", id={"type": "filter-add-group", "path": path_id}, 
                           className="btn btn-xs btn-outline-secondary")
            ])
        ])
        
    else: # Rule
        selected_col = node.get("col")
        selected_val = node.get("val", "")
        selected_op = node.get("op", "eq")
        
        # Get options for value dropdown based on selected column
        val_options = get_column_filter_options(selected_col, selected_val) if selected_col else []
        is_numeric = selected_col and selected_col in df.columns and pd.api.types.is_numeric_dtype(df[selected_col].dtype)
        
        # For numeric columns, 'contains' operator, or if no options, use Input
        if is_numeric or selected_op == "contains" or not val_options:
            value_component = dcc.Input(
                id={"type": "filter-rule-val", "path": path_id},
                value=selected_val,
                placeholder="Value",
                debounce=True,
                className="filter-input-small",
                style={"width": "120px"}
            )
        else:
            value_component = dcc.Dropdown(
                id={"type": "filter-rule-val", "path": path_id},
                options=val_options,
                value=selected_val if selected_val else None,
                placeholder="Select...",
                searchable=True,
                style={"width": "120px"},
                className="filter-dropdown-small"
            )

        return html.Div(style=style, className="filter-rule-row", children=[
            dcc.Dropdown(
                id={"type": "filter-rule-col", "path": path_id},
                options=[{"label": c, "value": c} for c in sorted(df.columns)],
                value=selected_col,
                placeholder="Column",
                style={"width": "120px"},
                className="filter-dropdown-small"
            ),
            dcc.Dropdown(
                id={"type": "filter-rule-op", "path": path_id},
                options=[
                    {"label": "=", "value": "eq"},
                    {"label": "≠", "value": "ne"},
                    {"label": ">", "value": "gt"},
                    {"label": "<", "value": "lt"},
                    {"label": "Contains", "value": "contains"},
                ],
                value=selected_op,
                style={"width": "80px"},
                className="filter-dropdown-small"
            ),
            value_component,
            html.Button("×", id={"type": "filter-rule-remove", "path": path_id}, 
                        className="btn btn-icon-small btn-danger")
        ])

