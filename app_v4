        },
    }

def apply_filters(dff, filter_node, logic="and"):
    """
    Apply filter rules to dataframe using a recursive structure.
    filter_node can be a list (legacy flat structure) or a dict (new recursive structure).
    """
    # Handle legacy list structure (migration)
    if isinstance(filter_node, list):
        if not filter_node:
            return dff
        # Convert flat list to a single group
        filter_node = {
            "type": "group",
            "logic": logic,
            "children": [{"type": "rule", **f} for f in filter_node]
        }
    
    # If None or empty
    if not filter_node:
        return dff
        
    def evaluate_node(node, df_subset):
        node_type = node.get("type", "group")
        
        if node_type == "group":
            children = node.get("children", [])
            node_logic = node.get("logic", "AND").upper()
            
            if not children:
                # Empty group returns True mask (all selected)
                return pd.Series(True, index=df_subset.index)
            
            # Evaluate all children
            child_results = [evaluate_node(child, df_subset) for child in children]
            
            # Combine results
            if not child_results:
                return pd.Series(True, index=df_subset.index)
                
            final_mask = child_results[0]
            for mask in child_results[1:]:
                if node_logic == "AND":
                    final_mask = final_mask & mask
                else: # OR
                    final_mask = final_mask | mask
            return final_mask
            
        elif node_type == "rule":
            col = node.get("col")
            op = node.get("op", "eq")
            val = node.get("val")
            
            val_str = str(val).strip()
            if not col or val is None or not val_str:
                # Incomplete rule returns True (ignored)
                return pd.Series(True, index=df_subset.index)
                
            val_list = [x.strip() for x in val_str.split(",")]
            
            try:
                # Check if this is a boolean column
                is_bool_col = col in df_subset.columns and pd.api.types.is_bool_dtype(df_subset[col].dtype)
                
                if op == "eq":
                    if is_bool_col:
                        bool_val = val_str.lower() in ("true", "1", "yes")
                        return df_subset[col] == bool_val
                    elif len(val_list) > 1:
                        return df_subset[col].astype(str).isin(val_list)
                    else:
                        try:
                            target = float(val_str)
                            return df_subset[col] == target
                        except:
                            return df_subset[col].astype(str) == val_str
                elif op == "ne":
                    if is_bool_col:
                        bool_val = val_str.lower() in ("true", "1", "yes")
                        return df_subset[col] != bool_val
                    else:
                        try:
                            target = float(val_str)
                            return df_subset[col] != target
                        except:
                            return df_subset[col].astype(str) != val_str
                elif op == "gt":
                    return df_subset[col] > float(val_str)
                elif op == "lt":
                    return df_subset[col] < float(val_str)
                elif op == "contains":
                    return df_subset[col].astype(str).str.contains(val_str, case=False, na=False)
                else:
                    return pd.Series(True, index=df_subset.index)
            except:
                return pd.Series(True, index=df_subset.index)
                
        return pd.Series(True, index=df_subset.index)

    # Apply the mask
    final_mask = evaluate_node(filter_node, dff)
    return dff[final_mask]

