@app.callback(
    Output("store-config", "data", allow_duplicate=True),
    # Global Filter Inputs
    Input({"type": "filter-group-logic", "path": ALL}, "value"),
    Input({"type": "filter-add-rule", "path": ALL}, "n_clicks"),
    Input({"type": "filter-add-group", "path": ALL}, "n_clicks"),
    Input({"type": "filter-group-remove", "path": ALL}, "n_clicks"),
    Input({"type": "filter-rule-remove", "path": ALL}, "n_clicks"),
    Input({"type": "filter-rule-col", "path": ALL}, "value"),
    Input({"type": "filter-rule-op", "path": ALL}, "value"),
    Input({"type": "filter-rule-val", "path": ALL}, "value"),
    
    # Pivot Management (Adding/Deleting Pivots)
    Input("btn-add-pivot", "n_clicks"),
    Input({"type": "delete-pivot", "pivot": ALL}, "n_clicks"),
    Input({"type": "pivot-title", "pivot": ALL}, "value"),
    Input({"type": "pivot-rows", "pivot": ALL}, "value"),
    Input({"type": "pivot-cols", "pivot": ALL}, "value"),
    Input({"type": "pivot-vals", "pivot": ALL}, "value"),
    
    State("store-config", "data"),
    prevent_initial_call=True
)
def update_filters_and_pivots(logic_vals, add_rule_clicks, add_group_clicks, 
                   remove_group_clicks, remove_rule_clicks,
                   col_vals, op_vals, val_vals,
                   add_pivot_click, delete_pivot_clicks,
                   pivot_titles, pivot_rows, pivot_cols, pivot_vals,
                   config):
    """
    Consolidated callback to handle all filter updates (Global and Pivot) and Pivot Configuration.
    """
    ctx_triggered = dash.callback_context.triggered
    if not ctx_triggered:
        return no_update
    
    trigger_id_str = ctx_triggered[0]['prop_id'].split('.')[0]
    
    # Handle Pivot Management (Add/Delete) - Simplest cases first
    if "btn-add-pivot" in trigger_id_str:
        config["pivots"].append(get_default_pivot_config())
        return config
        
    try:
        trigger_id = json.loads(trigger_id_str)
        action = trigger_id.get("type")
    except:
        return no_update

    # Handle Pivot Deletion/Updates
    if action == "delete-pivot":
        pivot_id = trigger_id["pivot"]
        config["pivots"] = [p for p in config["pivots"] if p["id"] != pivot_id]
        if not config["pivots"]:
             config["pivots"] = [get_default_pivot_config()]
        return config
        
    if action in ["pivot-title", "pivot-rows", "pivot-cols", "pivot-vals"]:
        pivot_id = trigger_id["pivot"]
        pivot = next((p for p in config.get("pivots", []) if p["id"] == pivot_id), None)
        if pivot:
            val = ctx_triggered[0]['value']
            if action == "pivot-title": pivot["title"] = val
            elif action == "pivot-rows": pivot["rows"] = val
            elif action == "pivot-cols": pivot["cols"] = val
            elif action == "pivot-vals": pivot["vals"] = val
        return config

    # Handle Filters (Recursive)
    path_str = trigger_id.get("path")
    if not path_str:
        return no_update

    # Helper to traverse and get parent node and index
    def get_node_at_path(root_node, path_indices):
        current = root_node
        if not path_indices: return current
        for i in path_indices:
            if "children" in current and i < len(current["children"]):
                current = current["children"][i]
            else: return None
        return current

    def get_parent_list_and_index(root_node, path_indices):
        if not path_indices: return None, None
        parent_indices = path_indices[:-1]
        child_index = path_indices[-1]
        parent = get_node_at_path(root_node, parent_indices)
        if parent and "children" in parent:
            return parent["children"], child_index
        return None, None

    # Parse path and get root
    is_global = path_str.startswith("global-filters")
    if is_global:
        root = config.get("global_filters", {})
        # Safety migration
        if isinstance(root, list):
             root = {"type": "group", "logic": "AND", "children": [{"type": "rule", **f} for f in root]}
             config["global_filters"] = root
        parts = path_str.split("-")[2:]
    else:
        # "pivot-{uuid}-filters-..."
        parts = path_str.split("-")
        pivot_id = parts[1]
        parts = parts[3:]
        pivot_config = next((p for p in config.get("pivots", []) if p["id"] == pivot_id), None)
        if not pivot_config: return no_update
        root = pivot_config.get("filters", {})
        if isinstance(root, list):
             root = {"type": "group", "logic": "AND", "children": [{"type": "rule", **f} for f in root]}
             pivot_config["filters"] = root
             
    path_indices = [int(p) for p in parts if p.isdigit()]
    
    # Perform Action
    if action == "filter-group-logic":
        value = ctx_triggered[0]['value']
        node = get_node_at_path(root, path_indices)
        if node: node["logic"] = value
            
    elif action == "filter-add-rule":
        node = get_node_at_path(root, path_indices)
        if node and node.get("type") == "group":
            node.setdefault("children", []).append({
                "type": "rule", "col": None, "op": "eq", "val": ""
            })
            
    elif action == "filter-add-group":
        node = get_node_at_path(root, path_indices)
        if node and node.get("type") == "group":
            node.setdefault("children", []).append({
                "type": "group", "logic": "AND", "children": []
            })
            
    elif action in ["filter-group-remove", "filter-rule-remove"]:
        parent_list, index = get_parent_list_and_index(root, path_indices)
        if parent_list is not None and index < len(parent_list):
            parent_list.pop(index)
            
    elif action in ["filter-rule-col", "filter-rule-op", "filter-rule-val"]:
        value = ctx_triggered[0]['value']
        node = get_node_at_path(root, path_indices)
        if node:
            if action == "filter-rule-col": node["col"] = value
            elif action == "filter-rule-op": node["op"] = value
            elif action == "filter-rule-val": node["val"] = value

    return config
    


