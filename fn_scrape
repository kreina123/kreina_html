import requests
import pandas as pd

# Collateral API endpoint
url = "https://fanniemae.mbs-securities.com/api/security/FNM/3140W1VA8/collateral"
params = {"recordType": "CURRENT"}

# Headers help you mimic a browser and avoid being blocked
