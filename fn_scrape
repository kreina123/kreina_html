    "User-Agent": "Mozilla/5.0 (Macintosh; Intel Mac OS X 10_15_7)",
    "Accept": "application/json, text/javascript, */*; q=0.01",
    "Referer": "https://fanniemae.mbs-securities.com/fannie/details/3140W1VA8",
}

# Make the request
